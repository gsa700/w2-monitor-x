<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:W2.App.ViewModels"
        x:Class="W2.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="470" SizeToContent="Height" CanResize="False"
        Background="{StaticResource BgBrush}"
        Icon="/Assets/app.ico"
        Title="W2 Monitor">

  <Grid Margin="16,12" RowDefinitions="Auto,Auto,Auto">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
      <TextBlock Grid.Column="0" Text="{Binding TitleText}" FontSize="20" FontWeight="Bold"
                 Foreground="{StaticResource HeroBrush}" VerticalAlignment="Center">
        <TextBlock.Effect>
          <DropShadowEffect Color="#3CC850" BlurRadius="12" OffsetX="0" OffsetY="0" Opacity="0.6"/>
        </TextBlock.Effect>
      </TextBlock>
      <Button Grid.Column="1" Content="Setup" IsEnabled="False"/>
    </Grid>

    <!-- Hero readouts (placeholder values in the scaffold) -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="0,14,0,0">
      <StackPanel Grid.Column="0">
        <TextBlock Text="FORWARD POWER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource DimBrush}"/>
        <TextBlock Text="{Binding PowerText}" FontFamily="Consolas" FontSize="34" FontWeight="Bold"
                   Foreground="{StaticResource HeroBrush}"/>
      </StackPanel>
      <StackPanel Grid.Column="1" HorizontalAlignment="Right">
        <TextBlock Text="SWR" FontSize="11" FontWeight="Bold" Foreground="{StaticResource DimBrush}"
                   HorizontalAlignment="Right"/>
        <TextBlock Text="{Binding SwrText}" FontFamily="Consolas" FontSize="34" FontWeight="Bold"
                   Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Right"/>
      </StackPanel>
    </Grid>

    <!-- Status -->
    <Border Grid.Row="2" Margin="0,14,0,0" Padding="10,8" Background="{StaticResource PanelBrush}" CornerRadius="4">
      <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource DimBrush}" TextWrapping="Wrap"/>
    </Border>

  </Grid>
</Window>
